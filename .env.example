# --- Authentication Options ---

# OPTION 1: Google AI Studio (Gemini API Key)
# Use this for quick development without a GCP project.
# GOOGLE_API_KEY=your-api-key-here
# GOOGLE_GENAI_USE_VERTEXAI=False

# OPTION 2: Vertex AI (Google Cloud)
# Use this for production-grade features in Google Cloud.
# Requires 'gcloud auth application-default login' OR a service account.
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# --- Application Configuration ---
# The BigQuery table to query for marketing analysis.
BQ_CUSTOMER_TABLE=marketing-agent-01-491314.customer_data_furniture.customer

# --- Multi-Environment UI Connectivity ---
# These are used by the custom Chat UI (make ui) to connect to remote agents.
# Get these IDs from 'make deploy-*' output or Google Cloud Console.
# DEV_AGENT_ENGINE_ID=projects/YOUR_PROJECT/locations/us-central1/reasoningEngines/YOUR_DEV_ID
# STAGING_AGENT_ENGINE_ID=projects/YOUR_PROJECT/locations/us-central1/reasoningEngines/YOUR_STG_ID
# PROD_AGENT_ENGINE_ID=projects/YOUR_PROJECT/locations/us-central1/reasoningEngines/YOUR_PROD_ID
